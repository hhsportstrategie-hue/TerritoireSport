# ── TerritoireSport — Variables d'environnement ──────────────────
# Copier ce fichier en .env et remplir les valeurs

# ── Base de données ──────────────────────────────────────────────
# Chemin vers le fichier SQLite
# Local : data/territoiresport.db
# Alwaysdata : $HOME/territoiresport/data/territoiresport.db
DB_PATH=data/territoiresport.db

# ── Environnement ────────────────────────────────────────────────
# development | production
ENV=production

# ── CORS ─────────────────────────────────────────────────────────
# Origines autorisées (séparées par virgules)
# * = toutes (dev uniquement)
# https://territoiresport.fr,https://www.territoiresport.fr = prod
ALLOWED_ORIGINS=*

# ── Alwaysdata ───────────────────────────────────────────────────
# Port fourni par Alwaysdata (généralement 8000 ou via $PORT)
PORT=8000

# ── Logs ─────────────────────────────────────────────────────────
# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO