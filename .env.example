# TerritoireSport — Variables d'environnement

# Base de données
DB_PATH=/app/data/territoiresport.db

# Authentification
API_TOKEN=territoire-sport-2026-secret-changez-moi

# Application
ENV=production
LOG_LEVEL=INFO
PORT=8000

# CORS
ALLOWED_ORIGINS=*

# Rate limiting (requêtes/minute)
RATE_LIMIT_PER_MINUTE=60
